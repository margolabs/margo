# Copy to `.env` before `docker compose up`.
#
# MARGO_HOST_TOKEN is the bearer token that boots the first superuser.
# Generate with:  openssl rand -hex 32
# This value is sensitive — treat it like a root password. After first
# boot you can issue per-user tokens via `host:create-token` and stop
# relying on this one.
MARGO_HOST_TOKEN=replace-me-with-openssl-rand-hex-32

# Identity for the bootstrap superuser. Used as the author signature
# on any commits the host writes before per-user accounts exist.
MARGO_HOST_USER_EMAIL=admin@your-domain
MARGO_HOST_USER_NAME=Margo Admin

# Optional: host-side port (default 7331). Internal container port
# stays 7331; this only changes the external mapping.
MARGO_HOST_PORT=7331
