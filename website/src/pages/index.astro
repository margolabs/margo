---
import Layout from '../layouts/Layout.astro';
import HeroDemo from '../components/HeroDemo.astro';
---

<Layout>
  <header class="topbar">
    <div class="brand">
      <span class="pin" aria-hidden="true">📌</span>
      <strong>margo</strong>
    </div>
    <nav>
      <a href="https://github.com/margolabs/margo">GitHub</a>
      <a href="https://www.npmjs.com/package/margo-dev">npm</a>
    </nav>
  </header>

  <section class="hero">
    <h1>Pin comments on your live app.<br /><span class="hero-em">AI implements them.</span></h1>
    <p class="lead">
      A shared annotation layer for AI-coding teams. PMs, designers, and devs leave comments on the
      running UI. Claude Code reads those comments as live context and makes the change.
      Comments live as files in your repo, synced over git — no SaaS, no extension to install.
    </p>

    <div class="cta-row">
      <pre class="install"><code>npm install -D margo-dev
npx margo init
npm run dev</code></pre>
      <div class="cta-buttons">
        <a class="btn btn-primary" href="https://github.com/margolabs/margo">View on GitHub</a>
        <a class="btn" href="https://www.npmjs.com/package/margo-dev">View on npm</a>
      </div>
    </div>

    <HeroDemo />
  </section>

  <section class="three-up">
    <article>
      <h3>1. Pin it</h3>
      <p>
        Click any element on the running app, type a comment. The overlay captures a hybrid anchor
        (selector + text + role + coords) so the pin survives refactors.
      </p>
    </article>
    <article>
      <h3>2. AI works it</h3>
      <p>
        Each comment is a markdown file in <code>.margo/comments/</code>. Claude Code reads them
        via the <code>/margo</code> skill, makes the code change, replies in-thread, bumps status
        to <code>ready-for-review</code>.
      </p>
    </article>
    <article>
      <h3>3. Humans review</h3>
      <p>
        Humans approve, reply, or mark resolved — through the same overlay UI. Resolved comments
        stay in place at <code>.margo/comments/&lt;id&gt;.md</code> so git blame works.
      </p>
    </article>
  </section>

  <section class="frameworks">
    <h2>Works with your stack</h2>
    <p class="lead">
      Two integration modes — same overlay, same workflow.
    </p>
    <div class="fw-grid">
      <div class="fw-card">
        <h3>Native plugin</h3>
        <p class="fw-list">Vite (vanilla, Vue, React, Svelte, Astro), Next.js App Router</p>
        <p class="fw-setup">One line in <code>vite.config.*</code> or <code>next.config.*</code>.</p>
      </div>
      <div class="fw-card">
        <h3>Sidecar + proxy</h3>
        <p class="fw-list">Angular, webpack-dev-server, Vue CLI, Create React App, SvelteKit (non-Vite), Remix-classic</p>
        <p class="fw-setup">
          Run <code>margo serve</code> next to your dev server; proxy <code>/__margo/*</code> to it.
        </p>
      </div>
    </div>
    <p class="see-more">
      Full setup for each framework is in the
      <a href="https://github.com/margolabs/margo#framework-support">README</a>.
      Demos for each integration ship in the
      <a href="https://github.com/margolabs/margo/tree/main">repo</a>.
    </p>
  </section>

  <section class="principles">
    <h2>Why this exists</h2>
    <ul>
      <li><strong>Humans never code.</strong> They only annotate. AI is the sole implementer.</li>
      <li><strong>Anchored to the running app, not files.</strong> Pins live on what users see, not on <code>file.ts:42</code>.</li>
      <li><strong>Git-native.</strong> Comments are markdown files in <code>.margo/comments/</code>, synced by <code>git pull/push</code>. No backend, no separate user system.</li>
      <li><strong>Single-user value on day one.</strong> A solo founder + Claude Code gets value before any second user.</li>
    </ul>
  </section>

  <footer class="footer">
    <p>
      <a href="https://github.com/margolabs/margo">github.com/margolabs/margo</a>
      ·
      <a href="https://www.npmjs.com/package/margo-dev">npmjs.com/package/margo-dev</a>
      ·
      MIT licensed
    </p>
  </footer>

  <style>
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      max-width: 1024px; margin: 0 auto; padding: 20px 32px;
    }
    .brand { display: inline-flex; align-items: center; gap: 8px; font-size: 16px; }
    .brand .pin { font-size: 18px; }
    .topbar nav { display: flex; gap: 18px; font-size: 14px; color: var(--muted); }
    .topbar nav a { text-decoration: none; }
    .topbar nav a:hover { color: var(--fg); }

    .hero {
      max-width: 880px; margin: 0 auto; padding: 60px 32px 40px;
      text-align: center;
    }
    .hero h1 {
      font-size: clamp(36px, 5vw, 56px);
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin: 0 0 18px;
      font-weight: 600;
    }
    .hero-em { color: var(--muted); }
    .hero .lead {
      font-size: clamp(15px, 1.6vw, 18px);
      color: var(--muted);
      max-width: 640px;
      margin: 0 auto 32px;
    }

    .cta-row {
      display: flex; flex-direction: column; align-items: center; gap: 16px;
      margin-bottom: 40px;
    }
    pre.install {
      background: var(--code-bg);
      color: var(--code-fg);
      border-radius: var(--radius);
      padding: 16px 20px;
      font-size: 14px;
      margin: 0;
      text-align: left;
      width: fit-content;
      max-width: 100%;
      overflow-x: auto;
    }
    pre.install code { background: none; padding: 0; color: inherit; }

    .cta-buttons { display: flex; gap: 12px; }
    .btn {
      display: inline-flex; align-items: center;
      padding: 10px 18px; border-radius: 9999px;
      font-size: 14px; font-weight: 500; text-decoration: none;
      border: 1px solid var(--border);
      transition: background-color .14s, border-color .14s, color .14s;
    }
    .btn:hover { background: var(--muted-bg); }
    .btn-primary {
      background: var(--accent); color: var(--accent-fg);
      border-color: var(--accent);
    }
    .btn-primary:hover { background: var(--fg); border-color: var(--fg); }


    .three-up {
      max-width: 1024px; margin: 80px auto; padding: 0 32px;
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
    }
    .three-up article {
      padding: 24px; border: 1px solid var(--border); border-radius: var(--radius);
      background: var(--bg);
    }
    .three-up h3 { margin: 0 0 8px; font-size: 16px; }
    .three-up p { margin: 0; font-size: 14px; color: var(--muted); }
    @media (max-width: 720px) {
      .three-up { grid-template-columns: 1fr; }
    }

    .frameworks {
      max-width: 1024px; margin: 80px auto; padding: 0 32px;
      text-align: center;
    }
    .frameworks h2 { font-size: clamp(24px, 3vw, 32px); margin: 0 0 12px; letter-spacing: -0.01em; }
    .frameworks .lead { color: var(--muted); margin: 0 0 32px; }
    .fw-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;
      text-align: left;
    }
    .fw-card {
      padding: 20px; border: 1px solid var(--border); border-radius: var(--radius);
    }
    .fw-card h3 { margin: 0 0 8px; font-size: 16px; }
    .fw-list { font-size: 13px; color: var(--muted); margin: 0 0 8px; }
    .fw-setup { font-size: 13px; margin: 0; }
    @media (max-width: 720px) {
      .fw-grid { grid-template-columns: 1fr; }
    }
    .see-more { font-size: 13px; color: var(--muted); margin-top: 18px; }
    .see-more a { color: inherit; }

    .principles {
      max-width: 880px; margin: 80px auto; padding: 0 32px;
    }
    .principles h2 { font-size: clamp(22px, 2.5vw, 28px); margin: 0 0 16px; letter-spacing: -0.01em; }
    .principles ul { padding-left: 18px; margin: 0; }
    .principles li { font-size: 15px; color: var(--muted); margin-bottom: 10px; }
    .principles li strong { color: var(--fg); font-weight: 600; }

    .footer {
      max-width: 1024px; margin: 80px auto 40px; padding: 24px 32px 0;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: 13px; color: var(--muted);
    }
    .footer a { color: inherit; }
  </style>
</Layout>
