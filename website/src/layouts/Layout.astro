---
interface Props {
  title?: string;
  description?: string;
}

const {
  // Title kept under 60 chars so OG validators don't flag it. Platforms
  // (Facebook, Twitter, LinkedIn, Slack) truncate longer titles in their
  // unfurl previews — shorter is the safer optimization.
  title = 'margo — pin live-app comments, AI implements them',
  description = 'Live-app feedback layer for AI-coding teams. Comments live as files in your repo; AI works through them.',
} = Astro.props;

const ogImageUrl = new URL('/og.png', Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        --bg: #ffffff;
        --fg: #0a0a0a;
        --muted: #6b7280;
        --muted-bg: #f4f4f5;
        --border: #e5e7eb;
        --accent: #0a0a0a;
        --accent-fg: #ffffff;
        --code-bg: #18181b;
        --code-fg: #e4e4e7;
        --radius: 10px;
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.55;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0a0a0a;
          --fg: #fafafa;
          --muted: #a1a1aa;
          --muted-bg: #18181b;
          --border: #27272a;
          --accent: #fafafa;
          --accent-fg: #0a0a0a;
          --code-bg: #18181b;
          --code-fg: #e4e4e7;
        }
      }
      * { box-sizing: border-box; }
      body { margin: 0; padding: 0; }
      a { color: inherit; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.92em; }
    </style>
  </body>
</html>
