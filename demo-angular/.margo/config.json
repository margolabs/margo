{
  "$schema": "https://margo-dev.com/schema/config.v0.json",
  "workspace": {
    "name": "margo-demo-angular",
    "appUrl": {
      "dev": "http://localhost:4200",
      "preview": null
    }
  },
  "roster": [
    { "email": "demo@margo.local", "role": "designer", "displayName": "Demo User" }
  ],
  "git": {
    "autoCommit": true,
    "autoPush":   false,
    "commitPrefix": "margo:",
    "branchPolicy": "current",
    "pullBeforePush": false
  },
  "ai": {
    "implicitTaskTrigger": true,
    "proactiveInboxSummaryAtSessionStart": true
  }
}
