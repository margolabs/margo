{
  "name": "margo-dev",
  "version": "0.0.17",
  "description": "Live-app feedback layer for AI-coding teams. Comments live as files in your repo; AI works through them.",
  "author": "Stanley Song <sxhuan@gmail.com>",
  "homepage": "https://gitlab.com/metaleap/margo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/metaleap/margo.git",
    "directory": "package"
  },
  "bugs": {
    "url": "https://gitlab.com/metaleap/margo/-/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/plugin/vite.js",
  "types": "./dist/plugin/vite.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin/vite.d.ts",
      "import": "./dist/plugin/vite.js"
    },
    "./vite": {
      "types": "./dist/plugin/vite.d.ts",
      "import": "./dist/plugin/vite.js"
    },
    "./next": {
      "types": "./dist/plugin/next.d.ts",
      "import": "./dist/plugin/next.js",
      "default": "./dist/plugin/next.js"
    },
    "./next-server": {
      "types": "./dist/plugin/next-server.d.ts",
      "import": "./dist/plugin/next-server.js",
      "default": "./dist/plugin/next-server.js"
    },
    "./next-client-script": {
      "types": "./dist/plugin/next-client-script.d.ts",
      "import": "./dist/plugin/next-client-script.js",
      "default": "./dist/plugin/next-client-script.js"
    },
    "./next-config": {
      "types": "./dist/plugin/next-config.d.ts",
      "import": "./dist/plugin/next-config.js",
      "default": "./dist/plugin/next-config.js"
    }
  },
  "bin": {
    "margo": "./dist/install/cli.js"
  },
  "files": [
    "dist",
    "src/templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-overlay.mjs",
    "dev": "tsc -w -p tsconfig.json",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "feedback",
    "annotation",
    "claude-code",
    "ai-coding",
    "vite-plugin",
    "nextjs",
    "design-collaboration",
    "comments",
    "review"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "next": ">=13",
    "react": ">=18",
    "vite": ">=4"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
